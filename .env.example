# bot
# discord
DISCORD_BOT_TOKEN=""

# twitch
# dev
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""

# bot
TWITCH_BOT_TOKEN="" 
TWITCH_BOT_ID=""

# Profile the bot should watch
TWITCH_OWNER_ID=""
TWITCH_CHANNEL="""

TWITCH_AD_MINUTES_PER_HOUR=3

# YouTube RSS (optional — omit to disable VideoWatcherCog)
YOUTUBE_CHANNEL_ID=""

# YouTube Live Chat bot (optional — omit to disable YouTube bot)
# YOUTUBE_CLIENT_SECRET_FILE: path to the client_secret.json downloaded from Google Cloud Console
# YOUTUBE_CHAT_TOKEN_FILE: where the OAuth token is stored after running scripts/youtube_chat_oauth.py
YOUTUBE_CLIENT_SECRET_FILE="/path/to/client_secret.json"
YOUTUBE_CHAT_TOKEN_FILE=".youtube_chat.tokens.pkl"

# LeetCode username (optional — enables streamer auto-submission detection)
LEETCODE_USERNAME=""

# Social links (comma-separated for multiple accounts)
SOCIAL_TWITCH="https://twitch.tv/yourchannel"
SOCIAL_YOUTUBE="https://youtube.com/@yourchannel"
SOCIAL_GITHUB="https://github.com/yourprofile"

# Database Configuration
DB_USER=""
DB_PASSWORD=""
DB_HOST=""
DB_PORT=1111
DB_NAME=""

# Observability (optional)
SENTRY_DSN=""
BOT_LOGS_WEBHOOK_URL=""

# Veil integration (optional — omit to disable event forwarding)
VEIL_URL=""
VEIL_SECRET=""
